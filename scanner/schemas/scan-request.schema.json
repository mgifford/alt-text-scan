{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.github.io/schemas/scan-request.schema.json",
  "title": "ScanRequest",
  "type": "object",
  "required": [
    "requestId",
    "issueNumber",
    "issueUrl",
    "submittedBy",
    "submittedAt"
  ],
  "properties": {
    "scanDomain": {
      "type": "string",
      "format": "uri",
      "description": "Root domain to discover URLs from (sitemap or crawl). Set when the issue title contains a URL and the body has no explicit URLs."
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "issueNumber": {
      "type": "integer",
      "minimum": 1
    },
    "issueUrl": {
      "type": "string",
      "format": "uri"
    },
    "submittedBy": {
      "type": "string",
      "minLength": 1
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestLabel": {
      "type": "string"
    },
    "issueTitle": {
      "type": "string"
    },
    "scanTitle": {
      "type": "string"
    },
    "engines": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["all", "axe", "alfa", "accesslint", "equalaccess", "qualweb"]
      },
      "minItems": 1
    },
    "maxPages": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2500,
      "description": "Maximum number of pages to discover in domain scan mode. Defaults to 100."
    },
    "pageLoadDelay": {
      "type": "integer",
      "minimum": 0,
      "maximum": 300
    },
    "requestedUrls": {
      "type": "array",
      "minItems": 0,
      "maxItems": 500,
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://"
      }
    }
  },
  "additionalProperties": false
}